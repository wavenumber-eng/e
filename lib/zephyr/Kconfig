menu "e"

config E
	bool "Enable E for embedded"

config E_VT100_ENABLE
	default n
	bool "Enables VT100 macro expansions for shell colors, etc"


config E_BQ_MAX_PRINTF_LEN
	int "Maximum BQ printf length"
	depends on E
	default 128
	range 32 1024
	help
	  Maximum length for BQ printf operations. This value determines
	  the buffer size allocated for formatted output operations.  This buffer is placed on the stack

config E_TICK_THREAD_STACK_SIZE
	int "stack size of the e tick thread"
	depends on E
	default 2048
	range 512 65536
	help
		stack size of the e tick thread

config E_LOG_ENABLE
	bool "enable e logging"
	default n
	depends on E
	help
		enable e logging

config E_LOG_RTT_ENABLE
	bool "enable e logging"
	default n
	depends on E_LOG_ENABLE
	help
		enable e logging

config E_LOG_RTT_TX_BUFFER_SIZE
	int "enable e logging"
	depends on E_LOG_RTT_ENABLE
	default 2048
	help
		enable e logging

config E_ACTIVITY_STACK_DEPTH
	int "Total depth of the activity stack"
	default 16
	help
		Total depth of the activity stack

config E_MSG_HEADER_1
	hex "Header byte 1"
	default 0xBE
	help
		Header byte 1

config E_MSG_HEADER_2
	hex "Header byte 2"
	default 0xEF
	help
		Header byte 2
        
config E_MSG_HEADER_3
	hex "Header byte 3"
	default 0xAA
	help
		Header byte 3

config E_MSG_HEADER_4
	hex "Header byte 4"
	default 0x55
	help
		Header byte 4
endmenu
